# Database
DATABASE_URL="postgresql://user:password@localhost:5432/customer_db"

# Server
PORT=3001
NODE_ENV=development

# OpenAI API
OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-4o-mini  # หรือ gpt-4o, gpt-3.5-turbo

# Facebook App (App ID: 1003947102810010)
FACEBOOK_APP_ID=1003947102810010
FACEBOOK_APP_SECRET=your_app_secret_here
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token_here
FACEBOOK_VERIFY_TOKEN=your_custom_verify_token_here  # ตั้งเองได้เลย เช่น "mySecretVerify123"

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Company Info (สำหรับ AI System Prompt)
COMPANY_NAME=ชื่อร้านของคุณ
COMPANY_TYPE=restaurant  # restaurant | cafe | shop | service
